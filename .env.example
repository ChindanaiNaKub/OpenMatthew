# CMU Matthew AI - OpenCode Plugin Configuration
# Copy this file to .env and fill in your values.

# Your CMU Account credentials (for testing the login flow)
CMU_TEST_USERNAME=your_username@cmu.ac.th
CMU_TEST_PASSWORD=your_password

# Optional: Override Matthew's Azure AD client ID
# MATTHEW_OAUTH_CLIENT_ID=5bedd6e5-ae10-4b96-abca-5c887092a70c

# Optional: Override the Matthew API base URL
# MATTHEW_API_BASE=https://matthew.cmu.ac.th
